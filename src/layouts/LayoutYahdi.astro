---
// LayoutYahdi — Layout dédié à Yahdi Qalbah Institute (Premium)
// N'importe PAS global.css pour éviter le flip dark mode qui casse les couleurs

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const SITE_URL = "https://saibodanfakha.com";
const {
	title = "Apprendre l'arabe du Coran — Yahdi Qalbah Institute",
	description = "Programme Rêve : apprenez l'arabe du Coran à partir de zéro. Cours en ligne 1-1, méthode progressive, spirituelle.",
	image = "/yahdi-og.jpg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = new URL(image, SITE_URL).toString();
const currentYear = new Date().getFullYear();
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Yahdi Qalbah Institute" />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Yahdi Qalbah" />
		<meta property="og:locale" content="fr_FR" />
		<meta property="og:image" content={ogImageUrl} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Google Fonts : Fraunces + Crimson Text -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Crimson+Text:ital@0;1&display=swap"
			rel="stylesheet"
		/>

		<!-- Styles YQ — couleurs sans dépendance à global.css -->
		<style is:global>
			:root {
				--yq-black: #0a0a0a;
				--yq-surface: #111111;
				--yq-surface-light: #0d0d0d;
				--yq-gold: #D4AF37;
				--yq-gold-dark: #B8860B;
				--yq-red: #C41E3A;
				--yq-text: #F5F0E8;
				--yq-text-muted: #9CA3AF;
				--yq-border: rgba(212, 175, 55, 0.1);
				--yq-border-accent: rgba(212, 175, 55, 0.25);
			}

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html, body {
				background-color: var(--yq-black);
				color: var(--yq-text);
				font-family: "Crimson Text", "Georgia", serif;
				font-size: 17px;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			h1, h2, h3, h4, h5, h6 {
				font-family: "Fraunces", Georgia, serif;
				letter-spacing: -0.02em;
			}

			h1, h2 {
				font-weight: 600;
			}

			button {
				font-family: inherit;
				cursor: pointer;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			/* Transitions premium — easeOutExpo */
			button, a, [data-magnetic] {
				transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
			}

			/* data-animate entrance */
			[data-animate] {
				opacity: 0;
				transform: translateY(24px);
			}

			[data-animate].is-visible {
				opacity: 1;
				transform: translateY(0);
				transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
			}

			/* Card hover premium */
			.yq-card {
				transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.yq-card:hover {
				transform: translateY(-4px) scale(1.005);
				box-shadow: 0 20px 40px rgba(212, 175, 55, 0.12);
			}
		</style>
	</head>
	<body class="min-h-screen flex flex-col">
		<!-- Header Yahdi Qalbah -->
		<header class="sticky top-0 z-50" style="background-color: var(--yq-black); border-bottom: 1px solid var(--yq-border-accent);">
			<div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
				<!-- Logo Yahdi Qalbah -->
				<a href="/" class="flex items-center gap-3 group">
					<img src="/yahdi-logo.png" alt="Yahdi Qalbah Institute" style="height: 3rem; object-fit: contain;" />
				</a>

				<!-- Navigation desktop -->
				<nav class="hidden md:flex items-center gap-8">
					<a href="#programme" class="yq-nav-link text-sm font-medium relative" style="color: var(--yq-text);">
						Programme
					</a>
					<a href="#contact" class="yq-nav-link text-sm font-medium relative" style="color: var(--yq-text);">
						Contact
					</a>
					<a href="https://www.youtube.com/@yahdiqalbah" target="_blank" rel="noopener noreferrer" class="yq-nav-link text-sm font-medium relative" style="color: var(--yq-text);">
						YouTube
					</a>
					<a href="#contact" class="text-sm font-semibold px-4 py-2 rounded" style="background-color: var(--yq-gold); color: var(--yq-black);">
						S'inscrire
					</a>
				</nav>

				<!-- Bouton menu mobile -->
				<button id="mobile-menu-btn" class="md:hidden text-base" style="color: var(--yq-gold);" aria-label="Ouvrir le menu" aria-expanded="false">
					<svg class="mobile-icon-open" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="4" y1="6" x2="20" y2="6"></line>
						<line x1="4" y1="12" x2="20" y2="12"></line>
						<line x1="4" y1="18" x2="20" y2="18"></line>
					</svg>
					<svg class="mobile-icon-close hidden" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="6" y1="6" x2="18" y2="18"></line>
						<line x1="6" y1="18" x2="18" y2="6"></line>
					</svg>
				</button>
			</div>

			<!-- Menu mobile -->
			<div id="mobile-menu" class="md:hidden hidden" style="background-color: var(--yq-black); border-top: 1px solid var(--yq-border);">
				<nav class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-4">
					<a href="#programme" class="mobile-link text-base font-medium py-2" style="color: var(--yq-text);">Programme</a>
					<a href="#contact" class="mobile-link text-base font-medium py-2" style="color: var(--yq-text);">Contact</a>
					<a href="https://www.youtube.com/@yahdiqalbah" target="_blank" rel="noopener noreferrer" class="mobile-link text-base font-medium py-2" style="color: var(--yq-text);">YouTube</a>
					<a href="#contact" class="text-base font-semibold px-4 py-2 rounded text-center" style="background-color: var(--yq-gold); color: var(--yq-black); margin-top: 8px;">S'inscrire</a>
				</nav>
			</div>

			<!-- Script menu mobile -->
			<script is:inline>
				(function () {
					const btn = document.getElementById("mobile-menu-btn");
					const menu = document.getElementById("mobile-menu");
					const iconOpen = btn?.querySelector(".mobile-icon-open");
					const iconClose = btn?.querySelector(".mobile-icon-close");
					if (!btn || !menu) return;

					function setOpen(open) {
						menu.classList.toggle("hidden", !open);
						iconOpen?.classList.toggle("hidden", open);
						iconClose?.classList.toggle("hidden", !open);
						btn.setAttribute("aria-expanded", String(open));
					}

					btn.addEventListener("click", () => {
						setOpen(menu.classList.contains("hidden"));
					});

					menu.querySelectorAll(".mobile-link").forEach((a) => {
						a.addEventListener("click", () => setOpen(false));
					});
				})();
			</script>
		</header>

		<!-- Main content -->
		<main class="flex-1">
			<slot />
		</main>

		<!-- Footer Yahdi Qalbah -->
		<footer class="mt-24 py-16" style="background-color: var(--yq-black); border-top: 4px solid var(--yq-gold);">
			<div class="max-w-6xl mx-auto px-6">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
					<!-- Logo + Description -->
					<div>
						<img src="/yahdi-logo.png" alt="Yahdi Qalbah Institute" style="height: 3rem; margin-bottom: 1.5rem; object-fit: contain;" />
						<p style="color: var(--yq-text-muted); font-size: 0.95rem; line-height: 1.7;">
							Institut Yahdi Qalbah — Apprendre l'arabe du Coran avec le Programme Rêve. Un voyage progressif vers la compréhension profonde du Qur'an.
						</p>
					</div>

					<!-- Navigation -->
					<div>
						<h3 style="font-family: 'Fraunces', Georgia, serif; font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--yq-gold); margin-bottom: 1.5rem;">
							Navigation
						</h3>
						<ul class="space-y-3 text-sm">
							<li><a href="#programme" style="color: var(--yq-text);">Programme Rêve</a></li>
							<li><a href="#contact" style="color: var(--yq-text);">Contact</a></li>
							<li><a href="https://www.youtube.com/@yahdiqalbah" target="_blank" rel="noopener noreferrer" style="color: var(--yq-text);">YouTube</a></li>
						</ul>
					</div>

					<!-- Contact -->
					<div>
						<h3 style="font-family: 'Fraunces', Georgia, serif; font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--yq-gold); margin-bottom: 1.5rem;">
							Contact
						</h3>
						<ul class="space-y-3 text-sm">
							<li>
								<a href="https://wa.me/221775277164?text=Salam, je suis intéressé par les cours d'arabe du Programme Rêve" target="_blank" rel="noopener noreferrer" style="color: var(--yq-text);">
									WhatsApp
								</a>
							</li>
							<li>
								<a href="mailto:courses@yahdiqalbah.com" style="color: var(--yq-text);">
									courses@yahdiqalbah.com
								</a>
							</li>
						</ul>
					</div>
				</div>

				<!-- Copyright -->
				<div class="border-t pt-8 text-xs text-center" style="border-color: var(--yq-border); color: var(--yq-text-muted);">
					<p>© {currentYear} Yahdi Qalbah Institute. "Lis le Coran avec confiance et douceur, pas à pas."</p>
				</div>
			</div>
		</footer>

		<!-- Smooth scroll + animations -->
		<script>
			import { initSmoothScroll } from "../scripts/smoothScroll";
			import { initMagnetic } from "../scripts/magnetic";
			import { initTextReveal } from "../scripts/textReveal";

			function safe(label: string, fn: () => void) {
				try { fn(); } catch (err) { console.error(`[${label}] init failed:`, err); }
			}

			safe("smoothScroll", initSmoothScroll);
			safe("magnetic", initMagnetic);
			safe("textReveal", initTextReveal);

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("is-visible");
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.15, rootMargin: "0px 0px -50px 0px" }
			);

			document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
