---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const SITE_URL = "https://saibodanfakha.com";
const {
	title = "Saïbo Danfakha — Sites web premium pour entrepreneurs & institutions",
	description = "Développeur web freelance Sénégal. Création de sites web sur-mesure pour entrepreneurs diaspora, PME et ONG. Design web premium, confiance et performance.",
	image = "/og-image.jpg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = new URL(image, SITE_URL).toString();
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="VeRzKfcCtLeD01MgzAiy6-YMu9kggyFKzA91nTTslAI" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Saïbo Danfakha" />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Hreflang pour contenu bilingue FR/EN -->
		<link rel="alternate" hreflang="fr" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={canonicalUrl} />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />

		<!-- Script région + thème : appliqué AVANT le rendu pour éviter le flash de contenu -->
		<script is:inline>
			(function () {
				// Région
				const savedRegion = localStorage.getItem("region");
				const region = savedRegion === "senegal" ? "senegal" : "diaspora";
				document.documentElement.classList.add("region-" + region);
				document.documentElement.dataset.region = region;

				// Thème (dark warm par défaut, theme-light si l'utilisateur a basculé)
				const savedTheme = localStorage.getItem("theme");
				if (savedTheme === "light") {
					document.documentElement.classList.add("theme-light");
				}
				document.documentElement.dataset.theme = savedTheme === "light" ? "light" : "dark";
			})();
		</script>

		<!-- Open Graph (partages WhatsApp, LinkedIn, Facebook) -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Saïbo Danfakha" />
		<meta property="og:locale" content="fr_FR" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Saïbo Danfakha — Designer & développeur web" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Schema.org (référencement) -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ProfessionalService",
			"name": "Saïbo Danfakha",
			"image": ogImageUrl,
			"description": description,
			"url": SITE_URL,
			"telephone": "+221775277164",
			"email": "zifo1819@gmail.com",
			"address": {
				"@type": "PostalAddress",
				"addressCountry": "SN",
				"addressLocality": "Dakar"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": "14.7167",
				"longitude": "-17.4677"
			},
			"openingHoursSpecification": {
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
				"opens": "09:00",
				"closes": "19:00"
			},
			"priceRange": "€€€",
			"areaServed": ["SN", "FR", "CA", "US", "GB"],
			"availableLanguage": ["French", "English"],
			"serviceType": [
				"Web Design",
				"Web Development",
				"UI/UX Design",
				"SEO Services"
			],
			"founder": {
				"@type": "Person",
				"name": "Saïbo Danfakha",
				"jobTitle": "Designer & développeur web freelance",
				"sameAs": [
					"https://www.linkedin.com/in/saibodanfakha/",
					"https://www.instagram.com/zira1819/"
				]
			},
			"sameAs": [
				"https://www.linkedin.com/in/saibodanfakha/",
				"https://www.instagram.com/zira1819/"
			]
		})} />

		<!-- Google Fonts : Fraunces (titres) + Inter (texte) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen flex flex-col">
		<Header />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />

		<!-- Smooth scroll global (Lenis) + Observer animations au scroll -->
		<script>
			import { initSmoothScroll } from "../scripts/smoothScroll";
			import { initCustomCursor } from "../scripts/cursor";
			import { initMagnetic } from "../scripts/magnetic";
			import { initTextReveal } from "../scripts/textReveal";
			import { initCounters } from "../scripts/counters";

			// Wrapper défensif : si un init plante, on log et on continue.
			function safe(label: string, fn: () => void) {
				try { fn(); } catch (err) { console.error(`[${label}] init failed:`, err); }
			}

			safe("smoothScroll", initSmoothScroll);
			safe("customCursor", initCustomCursor);
			safe("magnetic", initMagnetic);
			safe("textReveal", initTextReveal);
			safe("counters", initCounters);

			// Observer pour animations d'entrée — DOIT toujours tourner
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("is-visible");
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.15, rootMargin: "0px 0px -50px 0px" }
			);

			document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
