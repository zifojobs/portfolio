---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const SITE_URL = "https://saibodanfakha.com";
const {
	title = "Saïbo Danfakha — Sites web premium pour entrepreneurs & institutions",
	description = "Designer et développeur web freelance basé au Sénégal. Sites premium sur-mesure pour entrepreneurs, PME et institutions au Sénégal, en Afrique et à l'international — clients francophones et anglophones.",
	image = "/og-image.jpg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = new URL(image, SITE_URL).toString();
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Saïbo Danfakha" />
		<meta name="keywords" content="développeur web, designer web, freelance, Sénégal, site web premium, Astro, sur-mesure, Afrique de l'Ouest, international, francophone, anglophone, web developer Senegal" />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Script région + thème : appliqué AVANT le rendu pour éviter le flash de contenu -->
		<script is:inline>
			(function () {
				// Région
				const savedRegion = localStorage.getItem("region");
				const region = savedRegion === "senegal" ? "senegal" : "diaspora";
				document.documentElement.classList.add("region-" + region);
				document.documentElement.dataset.region = region;

				// Thème (dark warm par défaut, theme-light si l'utilisateur a basculé)
				const savedTheme = localStorage.getItem("theme");
				if (savedTheme === "light") {
					document.documentElement.classList.add("theme-light");
				}
				document.documentElement.dataset.theme = savedTheme === "light" ? "light" : "dark";
			})();
		</script>

		<!-- Open Graph (partages WhatsApp, LinkedIn, Facebook) -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Saïbo Danfakha" />
		<meta property="og:locale" content="fr_FR" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Saïbo Danfakha — Designer & développeur web" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Schema.org (référencement) -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Saïbo Danfakha",
			"jobTitle": "Designer & développeur web freelance",
			"url": SITE_URL,
			"email": "zifo1819@gmail.com",
			"telephone": "+221775277164",
			"address": { "@type": "PostalAddress", "addressCountry": "SN" },
			"sameAs": [
				"https://www.linkedin.com/in/saibodanfakha/",
				"https://www.instagram.com/zira1819/"
			]
		})} />

		<!-- Google Fonts : Fraunces (titres) + Inter (texte) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen flex flex-col">
		<Header />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />

		<!-- Smooth scroll global (Lenis) + Observer animations au scroll -->
		<script>
			import { initSmoothScroll } from "../scripts/smoothScroll";
			import { initCustomCursor } from "../scripts/cursor";
			import { initMagnetic } from "../scripts/magnetic";
			import { initTextReveal } from "../scripts/textReveal";
			import { initCounters } from "../scripts/counters";

			// 1. Smooth scroll premium (active dès que le DOM est prêt)
			initSmoothScroll();

			// 2. Curseur custom (desktop uniquement, désactivé en reduced-motion)
			initCustomCursor();

			// 3. Boutons magnétiques (desktop uniquement)
			initMagnetic();

			// 4. Reveal de titres au scroll
			initTextReveal();

			// 5. Compteurs animés
			initCounters();

			// 6. Observer pour animations d'entrée (déjà existant)
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("is-visible");
							observer.unobserve(entry.target); // animation une seule fois
						}
					});
				},
				{ threshold: 0.15, rootMargin: "0px 0px -50px 0px" }
			);

			document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
