// Filtrer les articles publiés (non-draft)
const articles = allArticles.filter(article => !article.draft);
---

<Layout
	title="Blog — Saïbo Danfakha"
	description="Articles sur le web design, le développement freelance et les conseils pour entrepreneurs. Crédibilité et expertise pour vos projets web."
>
	<section class="max-w-4xl mx-auto px-6 py-24 md:py-32">
		<a href="/" class="inline-flex items-center gap-2 text-sm text-sable-600 hover:text-noir-cafe transition-colors mb-12">
			<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
				<line x1="19" y1="12" x2="5" y2="12"></line>
				<polyline points="12 19 5 12 12 5"></polyline>
			</svg>
			Retour à l'accueil
		</a>

		<div class="mb-16">
			<p class="text-sm font-medium uppercase tracking-wider text-terracotta mb-4">
				Blog
			</p>
			<h1 class="text-4xl md:text-5xl font-semibold leading-tight tracking-tight text-noir-cafe mb-6">
				Articles sur le web design et le développement freelance
			</h1>
			<p class="text-xl text-sable-600">
				Des conseils concrets pour entrepreneurs, PME et institutions qui veulent un site web qui convertit.
			</p>
		</div>

		<div class="grid gap-8">
			{articles.map((article) => (
				<article class="group flex flex-col md:flex-row gap-6 p-6 bg-sable-100 border border-sable-300 rounded-xl hover:border-noir-cafe transition-colors">
					<a href={`/blog/${article.slug}/`} class="md:w-48 aspect-[4/3] bg-noir-cafe rounded-lg overflow-hidden flex-shrink-0 block">
						<img
							src={article.image}
							alt={article.alt}
							loading="lazy"
							class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
						/>
					</a>

					<div class="flex-1 flex flex-col">
						<div class="flex items-center gap-3 text-sm text-sable-600 mb-3">
							<time datetime={article.date}>
								{new Date(article.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
							</time>
							<span>·</span>
							<span>{article.tempsLecture} de lecture</span>
						</div>

						<h2 class="text-xl font-semibold text-noir-cafe mb-3 group-hover:text-terracotta transition-colors">
							<a href={`/blog/${article.slug}/`} class="hover:underline">
								{article.titre}
							</a>
						</h2>

						<p class="text-sable-600 mb-4 flex-1">
							{article.extrait}
						</p>

						<div class="flex flex-wrap gap-2">
							{article.tags.map((tag) => (
								<span class="px-2.5 py-1 bg-creme text-sable-600 rounded-full text-xs">
									#{tag}
								</span>
							))}
						</div>
					</div>
				</article>
			))}
		</div>

		<div class="mt-16 p-6 bg-terracotta/10 border border-terracotta/30 rounded-xl">
			<h3 class="text-lg font-semibold text-noir-cafe mb-3">
				Vous avez un projet web ?
			</h3>
			<p class="text-sable-600 mb-4">
				Discutons de votre projet ensemble. Je crée des sites premium pour entrepreneurs et institutions.
			</p>
			<a href="/#contact" class="inline-flex items-center gap-2 bg-noir-cafe text-creme px-6 py-3 rounded-md font-medium hover:bg-terracotta transition-colors">
				Me contacter
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"></line>
					<polyline points="12 5 19 12 12 19"></polyline>
				</svg>
			</a>
		</div>
	</section>
</Layout>
