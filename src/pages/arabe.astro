---
import LayoutYahdi from "../layouts/LayoutYahdi.astro";

const niveaux = [
	{
		numero: "01",
		titre: "Apprendre l'arabe à partir de 0",
		description: "Commence ton voyage avec la méthode Al-Qaa'ida An-Nouraniyyah. Tu apprendras à reconnaître et prononcer chaque lettre correctement.",
		sousPoints: [
			"Reconnaître et prononcer chaque lettre",
			"Lire des mots du Coran en peu de temps",
			"Te familiariser avec les versets du livre d'Allah dès les premiers jours",
		],
		tagline: "Lis le Coran avec confiance et douceur, pas à pas.",
	},
	{
		numero: "02",
		titre: "Fondamentaux de la grammaire arabe",
		description: "Entre dans la structure du langage du Coran. Maîtrise les fondements de la grammaire en identifiant les éléments essentiels d'une phrase coranique.",
		sousPoints: [
			"Maîtriser les fondements de la grammaire",
			"Identifier les éléments essentiels d'une phrase coranique",
			"Analyser des versets simples et comprendre leur sens",
		],
		tagline: "Parce que chaque mot du Qur'an a une sagesse, et chaque structure a un secret.",
		bonus: "Étude grammaticale complète de la sourate AL FAATIHA",
	},
	{
		numero: "03",
		titre: "Morphologie des mots (As-Sarf)",
		description: "Plonge dans la puissance linguistique du Coran. Comprends la racine des mots arabes et découvre comment les sens se transforment selon les formes.",
		sousPoints: [
			"Comprendre la racine des mots arabes",
			"Découvrir comment les sens se transforment selon les formes",
			"Conjuguer parfaitement en arabe",
		],
		tagline: "Tu ne liras plus les mots, tu les ressentiras et tu les comprendras.",
	},
	{
		numero: "04",
		titre: "Grammaire et structures avancées",
		description: "Atteins le niveau où le Coran s'ouvre devant toi. Comprends les structures complexes et analyse approfondie des versets.",
		sousPoints: [
			"Comprendre les structures complexes du Coran",
			"Analyse approfondie des versets",
			"Lecture consciente, réfléchie et spirituelle",
		],
		tagline: "Chaque verset deviendra une lumière et une certitude dans ton cœur.",
	},
];
---

<style>
	:root {
		--or: #D4AF37;
		--or-fonce: #B8860B;
		--rouge: #C41E3A;
		--rouge-clair: #E8B4B8;
		--blanc-creme: #F9F7F3;
		--gris-clair: #E8E6E1;
		--noir-texte: #2B2B2B;
		--noir-cafe: #1a1a1a;
	}

	body {
		background-color: var(--noir-cafe);
		color: var(--blanc-creme);
		font-family: "Crimson Text", "Georgia", serif;
	}

	.pattern-geometric {
		background-image:
			linear-gradient(45deg, transparent 48%, rgba(212, 175, 55, 0.05) 49%, rgba(212, 175, 55, 0.05) 51%, transparent 52%),
			linear-gradient(-45deg, transparent 48%, rgba(212, 175, 55, 0.05) 49%, rgba(212, 175, 55, 0.05) 51%, transparent 52%);
		background-size: 30px 30px;
		background-position: 0 0, 15px 15px;
		background-repeat: repeat;
	}

	.accent-or {
		color: var(--or);
	}

	.accent-rouge {
		color: var(--rouge);
	}

	.border-or {
		border-color: var(--or);
	}

	.bg-or {
		background-color: var(--or);
	}

	.bg-rouge {
		background-color: var(--rouge);
	}

	.hover-shine:hover {
		text-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
	}
</style>

<LayoutYahdi title="Programme Rêve — Apprendre l'arabe du Coran | Yahdi Qalbah" description="Cours d'arabe en ligne, méthode progressive du Programme Rêve. 4 niveaux du zéro au niveau avancé avec une approche spirituelle.">
	<!-- Hero Section — Spirituel et calme -->
	<section class="relative py-24 md:py-40 overflow-hidden">
		<div class="absolute inset-0 opacity-10 pattern-geometric"></div>
		<div class="absolute top-20 right-0 w-96 h-96 rounded-full bg-or/5 blur-3xl -mr-48"></div>
		<div class="absolute bottom-0 left-0 w-72 h-72 rounded-full bg-rouge/5 blur-3xl -ml-36"></div>

		<div class="relative max-w-5xl mx-auto px-6 text-center">
			<!-- Logo Yahdi Qalbah -->
			<div class="mb-12 flex justify-center">
				<img src="/yahdi-logo.png" alt="Yahdi Qalbah Institute" class="h-16 md:h-20" />
			</div>

			<!-- Titre principal -->
			<h1 class="text-5xl md:text-7xl font-serif font-semibold mb-6 accent-or leading-tight hover-shine transition-all duration-300">
				Apprendre l'arabe du Coran
			</h1>

			<!-- Sous-titre spirituel -->
			<p class="text-lg md:text-xl text-sable-300 font-serif italic mb-8 max-w-3xl mx-auto leading-relaxed">
				Un voyage progressif vers la compréhension profonde du Qur'an, guidé par la méthode du Programme Rêve.
			</p>

			<!-- Séparateur OR -->
			<div class="flex justify-center gap-3 mb-12">
				<div class="w-3 h-3 bg-or rounded-full"></div>
				<div class="w-3 h-3 bg-or rounded-full"></div>
				<div class="w-3 h-3 bg-or rounded-full"></div>
			</div>

			<!-- CTA Primaire -->
			<a href="https://wa.me/221775277164?text=Salam, je suis intéressé par les cours d'arabe du Programme Rêve" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-10 py-4 bg-or text-noir-cafe font-semibold text-lg rounded transition-all duration-300 hover:bg-or-fonce hover:shadow-xl hover:shadow-or/30">
				M'inscrire via WhatsApp
			</a>
		</div>
	</section>

	<!-- Section À propos du Programme Rêve -->
	<section class="relative py-24 md:py-32 bg-noir-cafe/50 border-y border-or/10">
		<div class="max-w-3xl mx-auto px-6 text-center">
			<h2 class="text-3xl md:text-4xl font-serif font-semibold mb-8 accent-or">
				Le Programme Rêve
			</h2>
			<p class="text-lg text-sable-300 font-serif italic mb-8 leading-relaxed">
				"Rêve" signifie que tu commences là où tu es et que tu chemines progressivement vers la maîtrise. Inspirée de la pédagogie de Nouman Ali Khan et de l'approche Bayyinah, cette méthode place le Coran au cœur de chaque leçon.
			</p>
			<div class="space-y-4 text-sable-200 text-base leading-relaxed">
				<p>
					Tu ne mémorises pas des règles abstraites. Tu apprends à <span class="accent-or font-semibold">lire, sentir et comprendre</span> chaque mot du Coran comme s'il parlait directement à ton cœur.
				</p>
				<p>
					Chaque niveau te rapproche d'une compréhension plus profonde, plus consciente, plus spirituelle. À la fin, le Coran n'est plus un texte en arabe — c'est un message vivant.
				</p>
			</div>
		</div>
	</section>

	<!-- Section Niveaux REVE — Cartes spirituelles -->
	<section id="programme" class="relative py-24 md:py-32">
		<!-- Motifs géométriques -->
		<div class="absolute left-0 top-1/4 w-40 h-40 border-2 border-or/10 rounded-3xl -translate-x-20"></div>
		<div class="absolute right-0 bottom-1/4 w-48 h-48 border-2 border-rouge/10 rounded-full translate-x-24"></div>

		<div class="relative max-w-5xl mx-auto px-6">
			<!-- En-tête Section -->
			<div class="mb-20 text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-or mb-3">Le chemin d'apprentissage</p>
				<h2 class="text-4xl md:text-5xl font-serif font-semibold accent-or leading-tight mb-6">
					Les 4 Niveaux du Programme Rêve
				</h2>
				<p class="text-lg text-sable-300 font-serif italic max-w-2xl mx-auto">
					Chaque niveau vous rapproche de la compréhension profonde et spirituelle du Qur'an.
				</p>
			</div>

			<!-- Grille des niveaux -->
			<div class="space-y-8">
				{niveaux.map((niveau, index) => (
					<div class={`relative border-l-4 border-or p-8 md:p-12 bg-noir-cafe/40 backdrop-blur-sm rounded-sm transition-all duration-300 hover:bg-noir-cafe/60 hover:shadow-lg hover:shadow-or/10 ${index % 2 === 0 ? '' : 'md:ml-8'}`}>
						<!-- Numéro et titre -->
						<div class="flex items-start gap-6 mb-8">
							<div class="flex-shrink-0">
								<span class="text-5xl font-serif font-semibold accent-or">{niveau.numero}</span>
							</div>
							<div class="flex-1">
								<h3 class="text-2xl md:text-3xl font-serif font-semibold text-blanc-creme mb-3">
									{niveau.titre}
								</h3>
								<p class="text-sable-300 leading-relaxed">
									{niveau.description}
								</p>
							</div>
						</div>

						<!-- Points clés -->
						<div class="ml-20 space-y-3 mb-8">
							{niveau.sousPoints.map((point) => (
								<div class="flex gap-3 items-start">
									<span class="text-or font-semibold text-lg leading-none mt-1">✦</span>
									<p class="text-sable-200">{point}</p>
								</div>
							))}
						</div>

						<!-- Tagline italique -->
						<div class="ml-20 pl-4 border-l-2 border-rouge/30 mb-4">
							<p class="text-sable-300 italic font-serif text-lg">
								"{niveau.tagline}"
							</p>
						</div>

						<!-- Bonus si présent -->
						{niveau.bonus && (
							<div class="ml-20 p-4 bg-or/10 border-l-2 border-or rounded-sm">
								<p class="text-sm text-blanc-creme">
									<span class="font-semibold accent-or">✨ Bonus :</span> {niveau.bonus}
								</p>
							</div>
						)}
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Section Infos Pratiques — Minimaliste OR/ROUGE -->
	<section class="relative py-20 md:py-24 bg-noir-cafe/50 border-y border-or/10">
		<div class="max-w-5xl mx-auto px-6">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- Info 1 — Prix -->
				<div class="text-center border-t-4 border-or pt-8">
					<p class="text-4xl md:text-5xl font-serif font-semibold accent-or mb-2">40€</p>
					<p class="text-sable-300 font-serif italic text-lg">Par mois</p>
					<p class="text-sm text-sable-400 mt-2">Cours individuels 1-1</p>
				</div>

				<!-- Info 2 — Temps -->
				<div class="text-center border-t-4 border-rouge pt-8">
					<p class="text-4xl md:text-5xl font-serif font-semibold accent-rouge mb-2">1h</p>
					<p class="text-sable-300 font-serif italic text-lg">Par semaine</p>
					<p class="text-sm text-sable-400 mt-2">Rythme flexible selon ton niveau</p>
				</div>

				<!-- Info 3 — Format -->
				<div class="text-center border-t-4 border-or pt-8">
					<p class="text-4xl md:text-5xl font-serif font-semibold accent-or mb-2">100%</p>
					<p class="text-sable-300 font-serif italic text-lg">En ligne</p>
					<p class="text-sm text-sable-400 mt-2">De n'importe où, à ton rythme</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Section CTA Final -->
	<section id="contact" class="relative py-24 md:py-32">
		<div class="absolute inset-0 opacity-10 pattern-geometric"></div>

		<div class="relative max-w-2xl mx-auto px-6 text-center">
			<!-- En-tête -->
			<h2 class="text-4xl md:text-5xl font-serif font-semibold accent-or mb-6 leading-tight">
				Prêt à commencer le voyage ?
			</h2>
			<p class="text-lg text-sable-300 font-serif italic mb-2">
				Réserve ta première leçon de découverte, entièrement gratuite.
			</p>
			<p class="text-sm text-sable-400 mb-10">
				Pas d'engagement — juste une conversation pour voir si le Programme Rêve te convient.
			</p>

			<!-- Séparateur -->
			<div class="flex justify-center gap-2 mb-10">
				<div class="w-2 h-2 bg-or rounded-full"></div>
				<div class="w-2 h-2 bg-or rounded-full"></div>
				<div class="w-2 h-2 bg-or rounded-full"></div>
			</div>

			<!-- CTA Button -->
			<a href="https://wa.me/221775277164?text=Salam, je suis intéressé par les cours d'arabe du Programme Rêve. Je voudrais une séance découverte gratuite." target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-12 py-5 bg-or text-noir-cafe font-semibold text-lg rounded transition-all duration-300 hover:bg-or-fonce hover:shadow-xl hover:shadow-or/40 hover:scale-105">
				Ouvrir WhatsApp
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2">
					<line x1="5" y1="12" x2="19" y2="12"></line>
					<polyline points="12 5 19 12 12 19"></polyline>
				</svg>
			</a>

			<!-- Alternative -->
			<p class="text-center text-sm text-sable-400 mt-8">
				Ou envoie-moi un message via WhatsApp directement au <a href="https://wa.me/221775277164" target="_blank" rel="noopener noreferrer" class="text-or font-semibold hover:text-or-fonce transition-colors">+221 77 527 71 64</a>
			</p>
		</div>
	</section>
</LayoutYahdi>
