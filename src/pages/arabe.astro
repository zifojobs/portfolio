---
import LayoutYahdi from "../layouts/LayoutYahdi.astro";

const niveaux = [
	{
		numero: "01",
		titre: "Débuts — Al-Qaa'ida",
		description: "Reconnais et prononce chaque lettre du Coran avec confiance.",
		sousPoints: [
			"Alphabet arabe complet",
			"Prononcer correctement",
			"Lire les premiers versets",
		],
		tagline: "Lis le Coran avec confiance, pas à pas.",
	},
	{
		numero: "02",
		titre: "Grammaire — An-Nahw",
		description: "Comprends la structure du Coran et ses éléments essentiels.",
		sousPoints: [
			"Fondements grammaticaux",
			"Éléments de phrase coranique",
			"Analyse de versets simples",
		],
		tagline: "Chaque structure a un secret.",
		bonus: "Étude complète de Sourate AL FAATIHA",
	},
	{
		numero: "03",
		titre: "Morphologie — As-Sarf",
		description: "Découvre les racines des mots et comment les sens se transforment.",
		sousPoints: [
			"Racines arabes",
			"Formes et sens variables",
			"Conjugaison parfaite",
		],
		tagline: "Tu ressentiras chaque mot.",
	},
	{
		numero: "04",
		titre: "Avancé — Tafsil",
		description: "Le Coran s'ouvre devant toi. Structures complexes, analyse profonde.",
		sousPoints: [
			"Structures complexes",
			"Analyse des versets",
			"Lecture consciente et spirituelle",
		],
		tagline: "Chaque verset, une lumière.",
	},
];
---

<style>
	/* Hero animation */
	.hero-word {
		display: inline-block;
		overflow: hidden;
	}

	.hero-blur {
		position: absolute;
		pointer-events: none;
	}

	.hero-blur-1 {
		width: 400px;
		height: 400px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(184, 134, 11, 0.06) 0%, transparent 70%);
		filter: blur(80px);
		top: 10%;
		right: -10%;
	}

	.hero-blur-2 {
		width: 350px;
		height: 350px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(196, 30, 58, 0.06) 0%, transparent 70%);
		filter: blur(80px);
		bottom: 5%;
		left: -5%;
	}

	/* Grid 2x2 pour les niveaux */
	.levels-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.levels-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* Card premium */
	.level-card {
		background-color: #111111;
		border: 1px solid rgba(184, 134, 11, 0.08);
		padding: 2.5rem;
		position: relative;
		overflow: hidden;
		transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.level-card:hover {
		transform: translateY(-4px) scale(1.005);
		box-shadow: 0 20px 40px rgba(184, 134, 11, 0.12);
	}

	.level-number {
		font-family: "Fraunces", Georgia, serif;
		font-size: 3.5rem;
		font-weight: 700;
		color: #b8860b;
		opacity: 0.6;
		text-align: right;
		margin-bottom: 1rem;
		line-height: 1;
	}

	.level-title {
		font-family: "Fraunces", Georgia, serif;
		font-size: 1.25rem;
		font-weight: 600;
		color: #ffffff;
		margin-bottom: 0.75rem;
	}

	.level-points {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 1.5rem 0;
	}

	.level-point {
		display: flex;
		gap: 0.75rem;
		color: #9CA3AF;
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.level-point-icon {
		color: #b8860b;
		font-weight: bold;
		flex-shrink: 0;
		margin-top: 0.125rem;
	}

	.level-tagline {
		font-family: "Crimson Text", Georgia, serif;
		font-style: italic;
		color: #6B7280;
		margin-top: 1rem;
		padding-left: 1rem;
		border-left: 2px solid rgba(196, 30, 58, 0.3);
		font-size: 0.95rem;
	}

	.level-bonus {
		margin-top: 1rem;
		padding: 0.875rem;
		background-color: rgba(184, 134, 11, 0.08);
		border-left: 2px solid #b8860b;
		font-size: 0.85rem;
	}

	.level-bonus-label {
		color: #b8860b;
		font-weight: 600;
	}

	.level-bonus-text {
		color: #ffffff;
	}

	/* Stats */
	.stats-section {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.stats-section {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.stat-block {
		text-align: center;
		border-top: 4px solid #b8860b;
		padding-top: 2rem;
	}

	.stat-number {
		font-family: "Fraunces", Georgia, serif;
		font-size: 3rem;
		@media (min-width: 768px) {
			font-size: 3.75rem;
		}
		font-weight: 700;
		color: #b8860b;
		line-height: 1;
		margin-bottom: 0.5rem;
	}

	.stat-label {
		font-size: 0.875rem;
		color: #9CA3AF;
	}

	/* Bouton CTA premium */
	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1.25rem 2rem;
		background-color: #b8860b;
		color: #000000;
		font-weight: 600;
		font-size: 1rem;
		border: none;
		cursor: pointer;
		transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.cta-button:hover {
		box-shadow: 0 0 40px rgba(184, 134, 11, 0.3);
		transform: translateY(-2px);
	}
</style>

<LayoutYahdi
	title="Programme Rêve — Apprendre l'arabe du Coran | Yahdi Qalbah"
	description="Cours d'arabe en ligne, méthode progressive du Programme Rêve. 4 niveaux du zéro au niveau avancé avec une approche spirituelle."
>
	<!-- Hero Section -->
	<section style="background-color: #000000; position: relative; padding: 6rem 1.5rem; overflow: hidden;">
		<!-- Background blurs -->
		<div class="hero-blur hero-blur-1"></div>
		<div class="hero-blur hero-blur-2"></div>

		<div style="max-width: 56rem; margin: 0 auto; position: relative; text-align: center;">
			<!-- Badge -->
			<div
				data-animate
				style="display: inline-block; background-color: rgba(184, 134, 11, 0.1); border: 1px solid rgba(184, 134, 11, 0.3); border-radius: 9999px; padding: 0.5rem 1rem; margin-bottom: 2rem; color: #b8860b; font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;"
			>
				Programme Rêve
			</div>

			<!-- H1 with hero words -->
			<h1
				style="font-family: 'Fraunces', Georgia, serif; font-size: 3.75rem; @media(min-width: 768px) { font-size: 4.5rem; } @media(min-width: 1024px) { font-size: 5rem; } font-weight: 600; line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 1.5rem;"
			>
				<div style="overflow: hidden; display: inline;">
					<span class="hero-word" style="color: #ffffff;">Apprendre</span>
				</div>
				<div style="overflow: hidden; display: inline;">
					<span class="hero-word" style="color: #ffffff;">l'arabe</span>
				</div>
				<br />
				<div style="overflow: hidden; display: inline;">
					<span class="hero-word" style="color: #b8860b; font-style: italic;">du Coran</span>
				</div>
			</h1>

			<!-- Subtitle -->
			<p
				data-animate
				style="font-family: 'Crimson Text', Georgia, serif; font-style: italic; font-size: 1.125rem; color: #9CA3AF; margin-bottom: 2rem; max-width: 42rem; margin-left: auto; margin-right: auto;"
			>
				Un voyage progressif vers la compréhension profonde du Qur'an.
			</p>

			<!-- Separator -->
			<div data-animate style="display: flex; justify-content: center; gap: 0.75rem; margin-bottom: 2rem;">
				<div style="width: 0.75rem; height: 0.75rem; background-color: #b8860b; border-radius: 50%;"></div>
				<div style="width: 0.75rem; height: 0.75rem; background-color: #b8860b; border-radius: 50%;"></div>
				<div style="width: 0.75rem; height: 0.75rem; background-color: #b8860b; border-radius: 50%;"></div>
			</div>

			<!-- CTA -->
			<a
				data-animate
				href="https://wa.me/221775277164?text=Salam, je suis intéressé par les cours d'arabe du Programme Rêve"
				target="_blank"
				rel="noopener noreferrer"
				data-magnetic
				class="cta-button"
			>
				M'inscrire via WhatsApp
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"></line>
					<polyline points="12 5 19 12 12 19"></polyline>
				</svg>
			</a>

			<!-- Stats -->
			<div data-animate style="margin-top: 3rem; display: flex; justify-content: center; gap: 2rem; font-size: 0.875rem; color: #9CA3AF;">
				<span>1 élève actif</span>
				<span>•</span>
				<span>40€/mois</span>
				<span>•</span>
				<span>100% en ligne</span>
			</div>
		</div>
	</section>

	<!-- Section Programme Rêve -->
	<section style="background-color: #0d0d0d; border-top: 1px solid rgba(184, 134, 11, 0.1); border-bottom: 1px solid rgba(184, 134, 11, 0.1); padding: 4rem 1.5rem;">
		<div style="max-width: 48rem; margin: 0 auto; text-align: center;">
			<h2
				data-animate
				style="font-family: 'Fraunces', Georgia, serif; font-size: 2rem; @media(min-width: 768px) { font-size: 2.25rem; } font-weight: 600; color: #b8860b; margin-bottom: 2rem;"
			>
				Le Programme Rêve
			</h2>
			<p
				data-animate
				style="font-family: 'Crimson Text', Georgia, serif; font-style: italic; font-size: 1.125rem; color: #ffffff; margin-bottom: 2rem; line-height: 1.8;"
			>
				"Rêve" signifie que tu commences là où tu es et que tu chemines progressivement vers la maîtrise. Inspirée de la pédagogie de Nouman Ali Khan et de Bayyinah, cette méthode place le Coran au cœur de chaque leçon.
			</p>
			<p
				data-animate
				style="color: #9CA3AF; margin-bottom: 1.5rem; line-height: 1.8;"
			>
				Tu ne mémorises pas des règles abstraites. Tu apprends à <span style="color: #b8860b; font-weight: 500;">lire, sentir et comprendre</span> chaque mot du Coran comme s'il parlait directement à ton cœur.
			</p>
		</div>
	</section>

	<!-- Section Niveaux -->
	<section id="programme" style="background-color: #000000; padding: 4rem 1.5rem;">
		<div style="max-w-5xl; margin: 0 auto;">
			<!-- Header -->
			<div data-animate style="text-align: center; margin-bottom: 4rem;">
				<p style="font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #b8860b; margin-bottom: 1rem;">
					Le chemin d'apprentissage
				</p>
				<h2
					style="font-family: 'Fraunces', Georgia, serif; font-size: 2.25rem; @media(min-width: 768px) { font-size: 3rem; } font-weight: 600; color: #ffffff; margin-bottom: 1.5rem; letter-spacing: -0.02em;"
				>
					Les 4 Niveaux du Programme Rêve
				</h2>
				<p style="color: #9CA3AF; font-size: 1.125rem;">
					Chaque niveau te rapproche de la compréhension profonde et spirituelle du Qur'an.
				</p>
			</div>

			<!-- Cards grid -->
			<div class="levels-grid" data-animate-stagger>
				{niveaux.map((niveau) => (
					<div class="level-card" data-animate>
						<div class="level-number">{niveau.numero}</div>
						<h3 class="level-title">{niveau.titre}</h3>
						<p style="color: #9CA3AF; font-size: 0.95rem; margin-bottom: 1rem;">{niveau.description}</p>

						<div class="level-points">
							{niveau.sousPoints.map((point) => (
								<div class="level-point">
									<span class="level-point-icon">✦</span>
									<span>{point}</span>
								</div>
							))}
						</div>

						<div class="level-tagline">"{niveau.tagline}"</div>

						{niveau.bonus && (
							<div class="level-bonus">
								<span class="level-bonus-label">✨ Bonus :</span>
								<span class="level-bonus-text"> {niveau.bonus}</span>
							</div>
						)}
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Section Infos pratiques -->
	<section style="background-color: #000000; border-top: 1px solid rgba(184, 134, 11, 0.1); border-bottom: 1px solid rgba(184, 134, 11, 0.1); padding: 3rem 1.5rem;">
		<div style="max-w-5xl; margin: 0 auto;">
			<div class="stats-section" data-animate>
				<div class="stat-block">
					<div class="stat-number">40€</div>
					<p style="color: #9CA3AF; font-style: italic;">Par mois</p>
					<p class="stat-label">Cours individuels 1-1</p>
				</div>

				<div class="stat-block">
					<div class="stat-number">1h</div>
					<p style="color: #9CA3AF; font-style: italic;">Par semaine</p>
					<p class="stat-label">Rythme flexible selon ton niveau</p>
				</div>

				<div class="stat-block">
					<div class="stat-number">100%</div>
					<p style="color: #9CA3AF; font-style: italic;">En ligne</p>
					<p class="stat-label">De n'importe où, à ton rythme</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Section CTA Final -->
	<section id="contact" style="background-color: #000000; position: relative; padding: 5rem 1.5rem; text-align: center;">
		<!-- Gradient ambient -->
		<div style="position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse at center, rgba(212,175,55,0.03) 0%, transparent 70%);"></div>

		<div style="max-width: 42rem; margin: 0 auto; position: relative;">
			<h2
				data-animate
				style="font-family: 'Fraunces', Georgia, serif; font-size: 2rem; @media(min-width: 768px) { font-size: 2.5rem; } font-weight: 600; color: #b8860b; margin-bottom: 1rem; letter-spacing: -0.02em;"
			>
				Prêt à commencer le voyage ?
			</h2>

			<p data-animate style="color: #9CA3AF; margin-bottom: 0.5rem;">
				Réserve ta première leçon de découverte, entièrement gratuite.
			</p>

			<p data-animate style="color: #6B7280; font-size: 0.95rem; margin-bottom: 2.5rem;">
				Pas d'engagement — juste une conversation pour voir si le Programme Rêve te convient.
			</p>

			<!-- Separator -->
			<div data-animate style="display: flex; justify-content: center; gap: 0.5rem; margin-bottom: 2rem;">
				<div style="width: 0.5rem; height: 0.5rem; background-color: #b8860b; border-radius: 50%;"></div>
				<div style="width: 0.5rem; height: 0.5rem; background-color: #b8860b; border-radius: 50%;"></div>
				<div style="width: 0.5rem; height: 0.5rem; background-color: #b8860b; border-radius: 50%;"></div>
			</div>

			<!-- CTA Button -->
			<a
				data-animate
				href="https://wa.me/221775277164?text=Salam, je suis intéressé par les cours d'arabe du Programme Rêve. Je voudrais une séance découverte gratuite."
				target="_blank"
				rel="noopener noreferrer"
				data-magnetic
				class="cta-button"
				style="font-size: 1.125rem; padding: 1.5rem 2.5rem;"
			>
				Ouvrir WhatsApp
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"></line>
					<polyline points="12 5 19 12 12 19"></polyline>
				</svg>
			</a>

			<p data-animate style="color: #6B7280; font-size: 0.875rem; margin-top: 2rem;">
				Ou WhatsApp directement au <a href="https://wa.me/221775277164" target="_blank" rel="noopener noreferrer" style="color: #b8860b; font-weight: 600;">+221 77 527 71 64</a>
			</p>
		</div>
	</section>

	<!-- GSAP Hero Animation -->
	<script>
		import gsap from "gsap";

		// Hero words animation
		const heroWords = document.querySelectorAll(".hero-word");
		const timeline = gsap.timeline();

		heroWords.forEach((word, index) => {
			timeline.fromTo(
				word,
				{ y: "110%", opacity: 0 },
				{ y: "0%", opacity: 1, duration: 0.8, ease: "expo.out" },
				index * 0.08
			);
		});

		// Animate badge and subtitle
		timeline.fromTo(".cta-button", { y: "20px", opacity: 0 }, { y: "0", opacity: 1, duration: 0.6, ease: "expo.out" }, "-=0.2");
	</script>
</LayoutYahdi>
