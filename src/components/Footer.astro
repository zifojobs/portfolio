---
// Footer — pied de page
// Inclut : signature, liens nav secondaire, contact rapide, copyright
const annee = new Date().getFullYear();
---

<footer class="bg-noir-cafe text-creme mt-24">
	<div class="max-w-6xl mx-auto px-6 py-16">

		<div class="grid grid-cols-1 md:grid-cols-4 gap-12">

			<!-- Colonne 1 — signature / wordmark -->
			<div class="md:col-span-2">
				<h2 class="font-serif font-semibold text-3xl tracking-tight mb-4">
					Saïbo Danfakha
				</h2>
				<p class="text-sable-300 text-sm leading-relaxed max-w-md">
					Designer & développeur web freelance basé à Kaolack, Sénégal. Sites premium et identités visuelles pour entrepreneurs et institutions.
				</p>
			</div>

			<!-- Colonne 2 — Navigation -->
			<div>
				<h3 class="font-serif text-sm font-semibold uppercase tracking-wider text-sable-300 mb-4">
					Navigation
				</h3>
				<ul class="space-y-3 text-sm">
					<li><a href="#offres" class="nav-link hover:text-terracotta transition-colors">Offres</a></li>
					<li><a href="#etudes-de-cas" class="nav-link hover:text-terracotta transition-colors">Études de cas</a></li>
					<li><a href="/blog/" class="nav-link hover:text-terracotta transition-colors">Blog</a></li>
					<li><a href="#a-propos" class="nav-link hover:text-terracotta transition-colors">À propos</a></li>
					<li><a href="#contact" class="nav-link hover:text-terracotta transition-colors">Contact</a></li>
				</ul>
			</div>

			<!-- Colonne 3 — Contact -->
			<div>
				<h3 class="font-serif text-sm font-semibold uppercase tracking-wider text-sable-300 mb-4">
					Contact
				</h3>
				<ul class="space-y-3 text-sm">
					<li>
						<a href="mailto:zifo1819@gmail.com" class="hover:text-terracotta transition-colors break-all">
							zifo1819@gmail.com
						</a>
					</li>
					<li>
						<a href="https://wa.me/221775277164" target="_blank" rel="noopener noreferrer" class="nav-link hover:text-terracotta transition-colors">
							+221 77 527 71 64
						</a>
					</li>
					<li class="text-sable-300">Sénégal</li>
				</ul>

				<!-- Réseaux sociaux -->
				<div class="mt-6 flex items-center gap-3">
					<a href="https://www.linkedin.com/in/saibodanfakha/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
						class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-sable-600/20 hover:bg-terracotta transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
							<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
						</svg>
					</a>
					<a href="https://www.instagram.com/zira1819/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
						class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-sable-600/20 hover:bg-terracotta transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
							<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
							<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
						</svg>
					</a>
				</div>
			</div>

		</div>

		<!-- Bas du footer -->
		<div class="mt-16 pt-8 border-t border-sable-600/30 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 text-xs text-sable-300">
			<p>© {annee} Saïbo Danfakha. Tous droits réservés.</p>
			<p>Conçu et développé avec soin au Sénégal 🇸🇳</p>
		</div>

	</div>
</footer>
